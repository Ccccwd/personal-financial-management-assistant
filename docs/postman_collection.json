	"item": [
		{
			"name": "1. 认证管理",
			"item": [
				{
					"name": "1.1 用户注册",
					"event": [{"listen": "test", "script": {"exec": [
						"var res = pm.response.json();",
						"pm.test('注册成功', function() {",
						"    pm.response.to.have.status(200);",
						"    pm.expect(res.code).to.eql(200);",
						"});",
						"pm.test('返回用户数据', function() {",
						"    pm.expect(res.data).to.have.property('id');",
						"    pm.expect(res.data.username).to.eql('postman_user');",
						"});"
					], "type": "text/javascript"}}],
					"request": {
						"auth": {"type": "noauth"},
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {"mode": "raw", "raw": "{\n  \"username\": \"postman_user\",\n  \"email\": \"postman@test.com\",\n  \"password\": \"test123456\"\n}"},
						"url": {"raw": "{{base_url}}/api/auth/register", "host": ["{{base_url}}"], "path": ["api", "auth", "register"]}
					}
				},
				{
					"name": "1.2 重复注册",
