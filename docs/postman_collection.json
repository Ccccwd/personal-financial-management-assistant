						"body": {"mode": "raw", "raw": "{\n  \"username\": \"postman_user\",\n  \"email\": \"postman@test.com\",\n  \"password\": \"test123456\"\n}"},
						"url": {"raw": "{{base_url}}/api/auth/register", "host": ["{{base_url}}"], "path": ["api", "auth", "register"]}
					}
				},
				{
					"name": "1.3 用户登录",
					"event": [{"listen": "test", "script": {"exec": [
						"var res = pm.response.json();",
						"pm.test('登录成功', function() {",
						"    pm.response.to.have.status(200);",
						"    pm.expect(res.code).to.eql(200);",
						"});",
						"pm.test('返回 access_token', function() {",
						"    pm.expect(res.data).to.have.property('access_token');",
						"    pm.expect(res.data).to.have.property('token_type');",
						"});",
						"if (res.data && res.data.access_token) {",
						"    pm.environment.set('token', res.data.access_token);",
						"}",
						"pm.test('Token 已保存', function() {",
						"    pm.expect(pm.environment.get('token')).to.be.a('string');",
						"});"
					], "type": "text/javascript"}}],
